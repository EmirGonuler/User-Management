@model List<UserManagement.Web.Models.UserViewModel>

@{
    ViewData["Title"] = "Users";
}

<div class="container mt-4">

    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>👥 User Management</h2>
        <a asp-action="Create" class="btn btn-primary">+ Add New User</a>
    </div>

    @* Success / Error alerts *@
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show">
            @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @* User count summary *@
    <p class="text-muted">
        Showing <strong>@Model.Count</strong> user(s) —
        <strong>@Model.Count(u => u.IsActive)</strong> active,
        <strong>@Model.Count(u => !u.IsActive)</strong> inactive.
    </p>

    <div class="table-responsive">
        <table class="table table-striped table-hover align-middle">
            <thead class="table-dark">
                <tr>
                    <th>Name</th>
                    <th>Email</th>
                    <th>Groups</th>
                    <th>Status</th>
                    <th>Created</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="6" class="text-center text-muted py-4">
                            No users found. Click "Add New User" to get started.
                        </td>
                    </tr>
                }
                @foreach (var user in Model)
                {
                    <tr>
                        <td>
                            <strong>@user.FullName</strong>
                        </td>
                        <td>@user.Email</td>
                        <td>
                            @if (user.Groups.Any())
                            {
                                @foreach (var group in user.Groups)
                                {
                                    <span class="badge bg-secondary me-1">@group</span>
                                }
                            }
                            else
                            {
                                <span class="text-muted">—</span>
                            }
                        </td>
                        <td>
                            @if (user.IsActive)
                            {
                                <span class="badge bg-success">Active</span>
                            }
                            else
                            {
                                <span class="badge bg-danger">Inactive</span>
                            }
                        </td>
                        <td>@user.CreatedAt.ToString("dd MMM yyyy")</td>
                        <td>
                            <a asp-action="Edit"
                                   asp-route-id="@user.Id"
                                   class="btn btn-sm btn-outline-primary me-1">
                                ✏️ Edit
                            </a>
                            <a asp-action="Delete"
                                   asp-route-id="@user.Id"
                                   class="btn btn-sm btn-outline-danger">
                                🗑️ Delete
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@model UserManagement.Web.Models.CreateUserViewModel

@{
    ViewData["Title"] = "Add New User";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8">

            <h2 class="mb-4">➕ Add New User</h2>

            <form asp-action="Create" method="post">
                @Html.AntiForgeryToken()

                <div asp-validation-summary="ModelOnly"
                     class="alert alert-danger" role="alert"></div>

                @* ── User Details ── *@
                <div class="card mb-4">
                    <div class="card-header fw-bold">👤 User Details</div>
                    <div class="card-body">

                        <div class="mb-3">
                            <label asp-for="FirstName" class="form-label"></label>
                            <input asp-for="FirstName" class="form-control"
                                   placeholder="e.g. John" />
                            <span asp-validation-for="FirstName"
                                  class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="LastName" class="form-label"></label>
                            <input asp-for="LastName" class="form-control"
                                   placeholder="e.g. Smith" />
                            <span asp-validation-for="LastName"
                                  class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Email" class="form-label"></label>
                            <input asp-for="Email" class="form-control"
                                   placeholder="e.g. john@example.com" />
                            <span asp-validation-for="Email"
                                  class="text-danger small"></span>
                        </div>

                    </div>
                </div>

                @* ── Group Assignment ── *@
                <div class="card mb-4">
                    <div class="card-header fw-bold">🏷️ Group Membership</div>
                    <div class="card-body">

                        @if (!Model.AvailableGroups.Any())
                        {
                            <p class="text-muted">No groups available.</p>
                        }
                        else
                        {
                            <p class="text-muted small mb-3">
                                Optionally assign this user to one or more groups.
                            </p>

                            @foreach (var group in Model.AvailableGroups)
                            {
                                <div class="card mb-2">
                                    <div class="card-body py-2">
                                        <div class="form-check">
                                            <input class="form-check-input"
                                                   type="checkbox"
                                                   name="SelectedGroupIds"
                                                   value="@group.Id"
                                                   id="group_@group.Id" />
                                            <label class="form-check-label fw-bold"
                                                   for="group_@group.Id">
                                                @group.Name
                                            </label>
                                            @if (!string.IsNullOrEmpty(group.Description))
                                            {
                                                <small class="text-muted ms-2">
                                                    — @group.Description
                                                </small>
                                            }
                                        </div>

                                        @if (group.Permissions.Any())
                                        {
                                            <div class="ms-4 mt-1">
                                                @foreach (var perm in group.Permissions)
                                                {
                                                    <span class="badge bg-secondary me-1"
                                                          title="@perm.Description">
                                                        🔑 @perm.Name (@perm.Level)
                                                    </span>
                                                }
                                            </div>
                                        }
                                    </div>
                                </div>
                            }
                        }

                    </div>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary">
                        💾 Save User
                    </button>
                    <a asp-action="Index" class="btn btn-outline-secondary">
                        Cancel
                    </a>
                </div>

            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
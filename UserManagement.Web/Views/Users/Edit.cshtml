@model UserManagement.Web.Models.UpdateUserViewModel

@{
    ViewData["Title"] = "Edit User";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8">

            <h2 class="mb-4">✏️ Edit User</h2>

            <form asp-action="Edit" asp-route-id="@Model.Id" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="Id" />

                @* Hidden inputs to pass current group IDs for diffing *@
                @for (int i = 0; i < Model.CurrentGroupIds.Count; i++)
                {
                    <input type="hidden"
                           name="CurrentGroupIds[@i]"
                           value="@Model.CurrentGroupIds[i]" />
                }

                <div asp-validation-summary="ModelOnly"
                     class="alert alert-danger" role="alert"></div>

                @* ── User Details ── *@
                <div class="card mb-4">
                    <div class="card-header fw-bold">👤 User Details</div>
                    <div class="card-body">

                        <div class="mb-3">
                            <label asp-for="FirstName" class="form-label"></label>
                            <input asp-for="FirstName" class="form-control" />
                            <span asp-validation-for="FirstName"
                                  class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="LastName" class="form-label"></label>
                            <input asp-for="LastName" class="form-control" />
                            <span asp-validation-for="LastName"
                                  class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Email" class="form-label"></label>
                            <input asp-for="Email" class="form-control" />
                            <span asp-validation-for="Email"
                                  class="text-danger small"></span>
                        </div>

                        <div class="form-check">
                            <input asp-for="IsActive"
                                   class="form-check-input"
                                   type="checkbox" />
                            <label asp-for="IsActive"
                                   class="form-check-label">Active User</label>
                        </div>

                    </div>
                </div>

                @* ── Group Assignment ── *@
                <div class="card mb-4">
                    <div class="card-header fw-bold">🏷️ Group Membership</div>
                    <div class="card-body">

                        @if (!Model.AvailableGroups.Any())
                        {
                            <p class="text-muted">No groups available.</p>
                        }
                        else
                        {
                            <p class="text-muted small mb-3">
                                Check the groups this user should belong to.
                                Each group's permissions are shown below it.
                            </p>

                            @foreach (var group in Model.AvailableGroups)
                            {
                                var isChecked = Model.SelectedGroupIds.Contains(group.Id);

                                <div class="card mb-2 @(isChecked ? "border-primary" : "")">
                                    <div class="card-body py-2">

                                        @* Group checkbox *@
                                        <div class="form-check">
                                            <input class="form-check-input"
                                                   type="checkbox"
                                                   name="SelectedGroupIds"
                                                   value="@group.Id"
                                                   id="group_@group.Id"
                                            @(isChecked ? "checked" : "") />
                                            <label class="form-check-label fw-bold"
                                                   for="group_@group.Id">
                                                @group.Name
                                            </label>
                                            @if (!string.IsNullOrEmpty(group.Description))
                                            {
                                                <small class="text-muted ms-2">
                                                    — @group.Description
                                                </small>
                                            }
                                        </div>

                                        @* Permissions belonging to this group *@
                                        @if (group.Permissions.Any())
                                        {
                                            <div class="ms-4 mt-1">
                                                @foreach (var perm in group.Permissions)
                                                {
                                                    <span class="badge bg-secondary me-1"
                                                          title="@perm.Description">
                                                        🔑 @perm.Name (@perm.Level)
                                                    </span>
                                                }
                                            </div>
                                        }

                                    </div>
                                </div>
                            }
                        }

                    </div>
                </div>

                @* ── Actions ── *@
                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary">
                        💾 Save Changes
                    </button>
                    <a asp-action="Index" class="btn btn-outline-secondary">
                        Cancel
                    </a>
                </div>

            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}